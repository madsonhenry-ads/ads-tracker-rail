{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": ["frontend/**"]
  },
  "deploy": {
    "root": "frontend",
    "buildCommand": "npm run build",
    "startCommand": "npx serve dist -s",
    "restartPolicyType": "ON_FAILURE"
  }
}
